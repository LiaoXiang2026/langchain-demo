# Git
.git/
.gitignore
.gitattributes

# Python 构建产物
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.venv/
venv/
env/
.pytest_cache/
htmlcov/
.coverage
.mypy_cache/
.ruff_cache/

# 前端源码中的 node_modules 和构建产物（源码进镜像用于多阶段构建）
frontend/node_modules/
frontend/dist/
frontend/.vite/

# 本地开发/Agent/IDE 产物
.claude/
.qoder/
.planning/
.cursor/
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# 运行期数据（通过 volume 挂载，不进镜像）
data/

# 密钥和本地环境覆盖
.env
.env.local
.env.*.local

# 测试和文档（生产镜像不需要）
tests/
docs/

# 项目文档（容器内用不到，但 README.md 必须保留：pyproject.toml 引用，hatchling 构建时校验）
*.md
!README.md
LICENSE*
